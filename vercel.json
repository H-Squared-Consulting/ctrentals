{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/proposal.html", "destination": "/proposal.html" },
    { "source": "/brochure.html", "destination": "/brochure.html" },
    { "source": "/brochures/:slug", "destination": "/api/brochure?slug=:slug" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
