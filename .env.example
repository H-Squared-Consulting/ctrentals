# Copy this file to .env and fill in the values.
# All VITE_-prefixed vars are inlined into the client bundle at build time,
# so they ship to the browser. Only put publishable keys here:
#  - the Supabase anon key (public by design; RLS is the security boundary)
#  - a Mapbox public token (pk.*)
# Never put a Supabase service-role key or any secret in a VITE_ var.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: map views in guidebooks fall back to a list when this is unset.
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token
